# Environment variables for expense function
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_HOST=your-db-host
DB_PORT=5432
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_SSL_ROOT_CERT=./ca.crt

# Budgets now live in the DB (amplop.budget_config); no MAX_* env vars in v2.

# Optional: Time override for testing (RFC3339 format)
# TIME=2025-09-06T10:00:00Z
