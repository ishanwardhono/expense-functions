# Environment variables for the Expense function
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_HOST=your-db-host
DB_PORT=5432
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# TLS mode. Production CockroachDB uses verify-full (needs DB_SSL_ROOT_CERT).
# A local insecure CockroachDB node uses "disable" (no cert needed); leave
# DB_PASSWORD empty for the insecure root user.
DB_SSL_MODE=verify-full
DB_SSL_ROOT_CERT=./ca.crt

# --- Local insecure CockroachDB in Docker (see README "Run locally") ---
# DB_HOST=localhost
# DB_PORT=26257
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=devdb
# DB_SSL_MODE=disable

# Budgets now live in the DB (amplop.budget_config); no MAX_* env vars in v2.

# Optional: Time override for testing / current-month pinning (RFC3339 format)
# TIME=2026-06-23T10:00:00Z
